# ── MyRide K-12 Authentication ────────────────────────────────────
# Capture these by running capture-tokens.js in your browser console
# while logged in to myridek12.tylerapp.com (see README for details).
#
# REFRESH TOKEN (recommended — auto-renews, lasts ~30 days)
MYRIDE_REFRESH_TOKEN=eyJjdHkiOiJKV1QiLCJlbmMiOiJBMjU2R0NNIiwiYWxnIjoiUlNBLU9BRVAifQ.........
#
# ACCESS TOKEN (fallback — paste a fresh one, expires in 60 minutes)
# MYRIDE_ACCESS_TOKEN=

# Your district's tenant ID (extracted from your JWT — see capture-tokens.js output)
MYRIDE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS Cognito settings (shared across all MyRide users — don't change these)
COGNITO_CLIENT_ID=3c5382gsq7g13djnejo98p2d98
COGNITO_REGION=us-east-1

# ── MQTT Broker (Home Assistant Mosquitto add-on) ─────────────────
MQTT_BROKER=homeassistant.local
MQTT_PORT=1883
MQTT_USERNAME=mqtt_user
MQTT_PASSWORD=mqtt_password
MQTT_TOPIC_PREFIX=myride

# ── Options ───────────────────────────────────────────────────────
# Manual bus filter override (optional).
# Normally the bridge auto-detects which bus(es) to track from the
# /api/student endpoint — no configuration required.
# Set this ONLY if you want to hard-lock to a specific bus ID and
# ignore the student-assignment API (e.g. "BUS 042").
BUS_FILTER=

# District timezone (IANA name). MyRide stop times are local to the district,
# so this is used to decide which run (AM/PM, regular/substitute) is currently
# active. Defaults to America/New_York if unset. Set it to your district's zone
# (e.g. America/Chicago) so run selection is correct regardless of the
# container's system timezone.
TZ=America/New_York

# Logging: debug, info, warn, error
LOG_LEVEL=info

# ── API Server (for token updates without restart) ────────────────
API_PORT=8099
# Token file path — use a Docker volume mount so it persists across recreates
TOKEN_FILE=/data/refresh_token
